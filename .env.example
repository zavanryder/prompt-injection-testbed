# API key for the target model (used by --model)
API_KEY=

# API key for the evaluation model (falls back to OPENAI_API_KEY, then API_KEY)
EVAL_API_KEY=

# OpenAI API key (used as fallback for evaluation if EVAL_API_KEY is not set)
OPENAI_API_KEY=

# Provider-specific keys (set whichever you need)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
OPENROUTER_API_KEY=

# Ollama (no key needed for local; set base URL for remote)
# OLLAMA_API_BASE=http://localhost:11434
